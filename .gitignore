.DS_Store
.env
.env.local
.env.*.local
.env.production.local
.env.development.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories and files
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
*.sublime-workspace
*.sublime-project

# OS
Thumbs.db
.DS_Store

# IDE
.vscode/
.idea/
*.iml
*.iws
*.ipr
*.swp
*.swo

# Vite
.vite/

# Capacitor
ios/
android/
.capacitor/
capacitor.config.json

# TypeScript
*.tsbuildinfo

# Rollup
.rolluprc.*

# Turbo
.turbo

# Storybook
storybook-static

# Cache
.cache
.eslintcache

# Local files
.DS_Store
.AppleDouble
.LSOverride
*.pem
*.key
*.cert

# Development
.env.development
.env.test

# Temporary files
tmp/
temp/
*.tmp

# macOS
.AppleDouble
.AppleDB
.DS_Store
.DocumentRevisions-V100
.FinderInfo
.LSQuarantine
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory

# npm
npm-debug.log
yarn-error.log

# Turbo
dist
.turbo

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# ESLint
.eslintcache

# Prettier
.prettierignore

# Husky
.husky

# Generated files
src/generated/
dist/

# IDE
.vscode/settings.json
.idea/
*.sublime-project
*.sublime-workspace

# OS specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
